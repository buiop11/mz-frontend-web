# 백엔드 루트 (슬래시 없이). 포트 80이면 생략 가능.
# 서버 전용 — 브라우저 번들에 포함되지 않음 (권장)
BACKEND_API_URL=http://localhost

# 또는 클라이언트에서도 같은 값이 필요할 때
# NEXT_PUBLIC_API_URL=http://localhost

# Google 로그인 (Google Cloud Console OAuth 클라이언트 ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# 변경 후 반드시: npm run dev 재시작
